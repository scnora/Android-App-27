<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <TextView
        android:id="@+id/backButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:text="‹"
        android:textColor="#8FC7F5"
        android:textSize="48sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/mainPhoto"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintBottom_toTopOf="@id/tagRecyclerView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/prevPhotoButton"
        android:layout_width="56dp"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="‹"
        android:textColor="#8FC7F5"
        android:textSize="56sp"
        android:background="#66000000"
        app:layout_constraintStart_toStartOf="@id/mainPhoto"
        app:layout_constraintTop_toTopOf="@id/mainPhoto"
        app:layout_constraintBottom_toBottomOf="@id/mainPhoto" />

    <TextView
        android:id="@+id/nextPhotoButton"
        android:layout_width="56dp"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="›"
        android:textColor="#8FC7F5"
        android:textSize="56sp"
        android:background="#66000000"
        app:layout_constraintEnd_toEndOf="@id/mainPhoto"
        app:layout_constraintTop_toTopOf="@id/mainPhoto"
        app:layout_constraintBottom_toBottomOf="@id/mainPhoto" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tagRecyclerView"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/mainPhoto"
        app:layout_constraintBottom_toTopOf="@id/photoThumbnailRecyclerView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/photoThumbnailRecyclerView"
        android:layout_width="0dp"
        android:layout_height="96dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tagRecyclerView"
        app:layout_constraintBottom_toTopOf="@id/addTagButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/addTagButton"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="30dp"
        android:backgroundTint="#1E1E1E"
        android:text="Add tag"
        android:textAllCaps="false"
        android:textColor="#8FC7F5"
        android:textSize="18sp"
        app:cornerRadius="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>